generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String         @id @default(cuid())
  email               String
  password            String
  name                String
  role                Role
  isApproved          Boolean        @default(false)
  denialReason        String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  patientProfile      Patient?
  doctorProfile       Doctor?
  pharmacistProfile   Pharmacist?
  doctorPrescriptions Prescription[] @relation("DoctorPrescriptions")
  doctorConsents      Consent[]      @relation("DoctorConsents")
  createdRecords      PatientRecord[] @relation("PatientRecordCreatedBy")
  doctorRecords       PatientRecord[] @relation("PatientRecordDoctor")
  accessLogs          AccessLog[]

  @@index([email])
  @@unique([email, role])
}

model Patient {
  id            String          @id @default(cuid())
  userId        String          @unique
  universalId   String          @unique
  dob           DateTime
  address       String
  phone         String
  heightCm      Float?
  weightKg      Float?
  user          User            @relation(fields: [userId], references: [id])
  prescriptions Prescription[]  @relation("PatientPrescriptions")
  consents      Consent[]       @relation("PatientConsents")
  records       PatientRecord[]
}

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  licenseNumber   String?
  specialization  String?
  hospitalOrgName String?
  phone           String?
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Pharmacist {
  id            String   @id @default(cuid())
  userId        String   @unique
  licenseNumber String?
  pharmacyName  String?
  phone         String?
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Prescription {
  id          String             @id @default(cuid())
  patientId   String
  doctorId    String
  status      PrescriptionStatus @default(PENDING)
  notes       String?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  medications Medication[]
  doctor      User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  patient     Patient            @relation("PatientPrescriptions", fields: [patientId], references: [id])
  linkedRecords PatientRecord[]

  @@index([patientId])
  @@index([doctorId])
}

model Medication {
  id             String       @id @default(cuid())
  prescriptionId String
  name           String
  dosage         String
  frequency      String
  duration       String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PHARMACIST
  PATIENT
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String
  role       AdminRole
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
  CANCELLED
  EXPIRED
}

model Medicine {
  id   String @id @default(cuid())
  name String @unique
}

model Consent {
  id            String        @id @default(cuid())
  patientId     String
  doctorId      String
  status        ConsentStatus @default(ACTIVE)
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime      @default(now())

  patient       Patient       @relation("PatientConsents", fields: [patientId], references: [id])
  doctor        User          @relation("DoctorConsents", fields: [doctorId], references: [id])

  @@unique([patientId, doctorId])
  @@index([patientId, status])
}

model PatientRecord {
  id                   String                    @id
  patientId            String
  createdByUserId      String
  doctorId             String?
  linkedPrescriptionId String?
  sourcePortal         PatientRecordSourcePortal
  category             PatientRecordCategory
  title                String
  description          String?
  tags                 String[]                  @default([])
  storagePath          String?
  originalFileName     String?
  mimeType             String?
  sizeBytes            Int?
  checksum             String?
  amount               Decimal?                  @db.Decimal(10, 2)
  occurredAt           DateTime                  @default(now())
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  patient              Patient                   @relation(fields: [patientId], references: [id])
  createdBy            User                      @relation("PatientRecordCreatedBy", fields: [createdByUserId], references: [id])
  doctor               User?                     @relation("PatientRecordDoctor", fields: [doctorId], references: [id])
  linkedPrescription   Prescription?             @relation(fields: [linkedPrescriptionId], references: [id])
  accessLogs           AccessLog[]

  @@index([patientId, occurredAt])
  @@index([patientId, category, occurredAt])
}

model AccessLog {
  id              String        @id @default(cuid())
  patientRecordId String
  userId          String?
  userName        String?
  accessType      String
  reason          String?
  ipAddress       String?
  userAgent       String?
  timestamp       DateTime      @default(now())
  notes           String?
  patientRecord   PatientRecord @relation(fields: [patientRecordId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])

  @@index([patientRecordId, timestamp])
  @@index([userId, timestamp])
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PatientRecordCategory {
  PRESCRIPTION
  LAB_REPORT
  IMAGING
  CONSULTATION_NOTE
  DISCHARGE_SUMMARY
  MEDICAL_BILL
  OTHER
}

enum PatientRecordSourcePortal {
  PATIENT
  DOCTOR
}
